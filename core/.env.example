# ============================================================
#  travel-edit 환경 설정 예시
#  이 파일을 core/.env 로 복사한 뒤 값을 채워 사용하세요.
#  cp core/.env.example core/.env
# ============================================================

# ── API 키 (최소 ANTHROPIC_API_KEY 하나는 필요) ─────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=        # 선택 — Claude rate limit 시 폴백
GEMINI_API_KEY=        # 선택 — Claude/OpenAI rate limit 시 폴백

# ── 모델 선택 ────────────────────────────────────────────────
# 단축 별칭: haiku | sonnet | opus | mini | flash 등
CLAUDE_MODEL=haiku
OPENAI_MODEL=mini
GEMINI_MODEL=flash

# ── STT 정제 ─────────────────────────────────────────────────
STT_REFINE=true
STT_REFINE_MODEL=haiku

# ── 편집 스타일 ──────────────────────────────────────────────
# balanced | voice | scene-short | scene-long | highlight | vlog
EDIT_STYLE=balanced

# ── 출력 해상도 ──────────────────────────────────────────────
# auto | 4k | 1440p | fhd | 720p | 3840x2160
OUTPUT_RESOLUTION=auto

# ── 인코더 설정 ──────────────────────────────────────────────
VIDEO_CODEC=h265          # h264 | h265
CRF=24                    # 낮을수록 고화질·대용량 (H.265 기준: 18~28)
FFMPEG_PRESET=medium      # ultrafast | fast | medium | slow

# ── NVIDIA GPU 인코딩 (NVENC) ─────────────────────────────────
USE_NVENC=auto            # auto | true | false
NVENC_PRESET=p4           # p1(최속) ~ p7(최고품질)
NVENC_MAX_SESSIONS=3      # GeForce 소비자용 GPU 기본값

# ── Whisper STT ──────────────────────────────────────────────
# 모델: tiny | base | small | medium | large-v3 | distil-large-v3
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda       # cuda | cpu
WHISPER_COMPUTE_TYPE=int8

# ── 자막 ─────────────────────────────────────────────────────
SUBTITLE_LANG=auto        # auto | ko | en | ja | zh | off
SUBTITLE_MODE=overlay     # overlay | srt

# ── 병렬 처리 ────────────────────────────────────────────────
EVAL_WORKERS=5            # 동시 AI 평가 수
TRANSCRIBE_WORKERS=0      # 0 = 자동
RENDER_WORKERS=0          # 0 = cpu_count // 2 자동

# ── 기타 옵션 ────────────────────────────────────────────────
SPLIT_ORIENTATION=false   # true = 가로/세로 영상 별도 출력
MIN_DAY_DURATION=0        # 하루 최소 영상 길이(초), 0 = 비활성
CLIP_SUMMARY=true         # 컷별 요약 리포트(clips_summary.json/csv, selected_clips.json) 생성
SILENT_SPEEDUP=1.0        # 음성 없는 컷 배속 (1.0=비활성, 예: 2.0=무음 컷 2배속)
FACE_MOSAIC=false
FACE_MOSAIC_KOREA_ONLY=false
FACE_MOSAIC_FAMILY_EXCLUDE=false
ARCHIVE_DIR=              # 렌더링 후 이동할 경로 (비워두면 이동 안 함)
